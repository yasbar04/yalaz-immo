# Core Django settings
SECRET_KEY=change-me-with-a-long-random-secret-key-generated-for-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,testserver
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Security defaults
# In production, set DEBUG=False and switch the values below to the secure variant.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_REFERRER_POLICY=same-origin
X_FRAME_OPTIONS=DENY
USE_X_FORWARDED_PROTO=False

# Branding / app URLs
PLATFORM_NAME=Yalaz
APP_BASE_URL=http://127.0.0.1:8000

# Email (transactionnel)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@yalaz.com
# TRANSACTIONAL_FROM_EMAIL=hello@yalaz.com

# Verification
VERIFICATION_CODE_TTL_MINUTES=10
VERIFICATION_RESEND_COOLDOWN_SECONDS=60
VERIFICATION_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_LINK_MAX_AGE=86400

# SMS
SMS_BACKEND=console
# SMS_BACKEND=twilio
# SMS_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SMS_TWILIO_AUTH_TOKEN=your-twilio-auth-token
# SMS_TWILIO_FROM_NUMBER=+1234567890
