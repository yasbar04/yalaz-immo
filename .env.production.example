# PRODUCTION ENVIRONMENT - Copy to .env and fill in values

# Core Django
SECRET_KEY=generate-a-strong-random-key-here-min-50-chars
DEBUG=False
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# Database (PostgreSQL)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=aylaz
DB_USER=aylaz_user
DB_PASSWORD=strong-password-here
DB_HOST=db
DB_PORT=5432

# Security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
X_FRAME_OPTIONS=DENY
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
USE_X_FORWARDED_PROTO=True

# Branding
PLATFORM_NAME=Aylaz
APP_BASE_URL=https://your-domain.com

# Email (SendGrid, Mailgun, AWS SES, etc.)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@your-domain.com
TRANSACTIONAL_FROM_EMAIL=hello@your-domain.com

# Cache (Redis)
REDIS_URL=redis://redis:6379/0
CACHE_TIMEOUT=300

# Verification
VERIFICATION_CODE_TTL_MINUTES=10
VERIFICATION_RESEND_COOLDOWN_SECONDS=60
VERIFICATION_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_LINK_MAX_AGE=86400

# SMS (Twilio)
SMS_BACKEND=twilio
SMS_TWILIO_ACCOUNT_SID=your-account-sid
SMS_TWILIO_AUTH_TOKEN=your-auth-token
SMS_TWILIO_FROM_NUMBER=+1234567890

# Monitoring (Sentry)
SENTRY_DSN=your-sentry-dsn-url
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# API Keys
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com,https://api.your-domain.com
